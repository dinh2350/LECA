{
  "name": "@n2base/web",
  "version": "1.1.0",
  "private": true,
  "engines": {
    "node": ">=22",
    "pnpm": ">=9"
  },
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "build:e2e": "cp -n example.env.local .env.local && next build",
    "start": "next start",
    "lint": "eslint .",
    "release": "release-it",
    "generate:resource": "hygen generate resource",
    "postgenerate:resource": "pnpm run lint -- --fix",
    "lint:fix": "eslint . --fix",
    "generate:field": "hygen generate field",
    "postgenerate:field": "pnpm run lint -- --fix",
    "test:e2e": "playwright test",
    "sb": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@faker-js/faker": "10.3.0",
    "@hookform/resolvers": "5.2.2",
    "@n2base/schemas": "workspace:*",
    "@react-oauth/google": "0.13.4",
    "@tanstack/react-query": "5.95.2",
    "@tanstack/react-query-devtools": "5.95.2",
    "@tiptap/extension-placeholder": "^3.23.6",
    "@tiptap/pm": "^3.23.6",
    "@tiptap/react": "^3.23.6",
    "@tiptap/starter-kit": "^3.23.6",
    "@types/node": "25.5.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "accept-language": "3.0.20",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "3.6.0",
    "dotenv": "17.3.1",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.0",
    "i18next": "25.10.10",
    "i18next-browser-languagedetector": "8.2.1",
    "i18next-resources-to-backend": "1.2.1",
    "js-cookie": "3.0.5",
    "lucide-react": "^1.16.0",
    "nanoid": "5.1.7",
    "next": "16.2.0",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "19.2.4",
    "react-day-picker": "^10.0.1",
    "react-dom": "19.2.4",
    "react-dropzone": "15.0.0",
    "react-hook-form": "7.72.0",
    "react-i18next": "16.6.2",
    "react-virtuoso": "4.18.3",
    "shadcn": "^4.8.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "5.9.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "5.0.2",
    "@eslint/eslintrc": "3.3.5",
    "@eslint/js": "9.39.4",
    "@n2base/eslint-config": "workspace:*",
    "@n2base/tsconfig": "workspace:*",
    "@playwright/test": "1.58.2",
    "@release-it/conventional-changelog": "10.0.6",
    "@storybook/addon-docs": "10.3.1",
    "@storybook/addon-links": "10.3.1",
    "@storybook/addon-onboarding": "10.3.1",
    "@storybook/nextjs": "10.3.1",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/js-cookie": "3.0.6",
    "@typescript-eslint/eslint-plugin": "8.57.1",
    "@typescript-eslint/parser": "8.57.1",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-storybook": "10.3.1",
    "hygen": "6.2.11",
    "postcss": "^8.5.15",
    "release-it": "19.2.4",
    "storybook": "10.3.1",
    "tailwindcss": "^4.3.0"
  },
  "release-it": {
    "$schema": "https://unpkg.com/release-it/schema/release-it.json",
    "git": {
      "commitMessage": "chore: release v${version}"
    },
    "github": {
      "release": true
    },
    "npm": {
      "publish": false
    },
    "plugins": {
      "@release-it/conventional-changelog": {
        "infile": "CHANGELOG.md",
        "preset": {
          "name": "conventionalcommits",
          "types": [
            {
              "type": "feat",
              "section": "Features"
            },
            {
              "type": "fix",
              "section": "Bug Fixes"
            },
            {
              "type": "perf",
              "section": "Performance Improvements"
            },
            {
              "type": "revert",
              "section": "Reverts"
            },
            {
              "type": "docs",
              "section": "Documentation"
            },
            {
              "type": "refactor",
              "section": "Code Refactoring"
            },
            {
              "type": "test",
              "section": "Tests"
            },
            {
              "type": "ci",
              "section": "Continuous Integration"
            }
          ]
        }
      }
    }
  },
  "overrides": {
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3"
  }
}
